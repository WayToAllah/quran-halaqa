{
  "name": "quran-halaqa-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:components": "vitest run --config vitest.components.config.ts",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore,auth --project demo-quran-halaqa-rules-test \"vitest run --config vitest.rules.config.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:rules": "tsc --noEmit -p tsconfig.rules.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "migrate": "tsx scripts/migrate-rtdb-to-firestore.ts"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "preact": "^10.29.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "firebase-tools": "^15.22.4",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
