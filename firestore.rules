rules_version = '2';

// ============================================================================
// متابعة حفظ القرآن — Firestore Security Rules (Phase 2)
//
// Model: mosques/{mosqueId} owns halaqat/{halaqaId}, which owns its own
// students/records. Access to everything under a mosque requires a
// members/{uid} doc under that mosque — there is no blanket "any signed-in
// user can read/write anything" rule like the old RTDB `auth != null` grant.
//
// publicStats/{token} is the one deliberately public read exception:
// child.html reads a single doc by a high-entropy token, with no sign-in at
// all. `get` is allowed, `list` is denied (tokens can never be enumerated).
//
// WRITE is currently allowed to any signed-in user (the admin app recomputes
// and publishes the projection on every save/delete — same trust model as the
// live RTDB app today). This is a TRANSITIONAL grant: Phase 5 moves the write
// into a Cloud Function and flips this back to `write: if false` so no client
// can write it at all. Tracked in PROJECT_CONTEXT.md.
//
// Verify with the Rules Playground in Firebase Console, or (preferred, and
// what the CI workflow in .github/workflows/ci.yml runs automatically)
// `firebase emulators:exec` against firestore.rules.test.ts.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMosqueMember(mosqueId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/mosques/$(mosqueId)/members/$(request.auth.uid));
    }

    match /mosques/{mosqueId} {
      allow read: if isMosqueMember(mosqueId);
      // Mosque documents themselves are created/managed out-of-band (Firebase
      // Console or an Admin SDK script), never by a client — prevents anyone
      // from, say, renaming the mosque or granting themselves membership.
      allow write: if false;

      match /members/{uid} {
        allow read: if isMosqueMember(mosqueId);
        allow write: if false; // membership managed by Admin SDK/Console only
      }

      match /halaqat/{halaqaId} {
        allow read, write: if isMosqueMember(mosqueId);

        match /students/{studentId} {
          allow read, write: if isMosqueMember(mosqueId);
        }

        match /records/{recordId} {
          allow read, write: if isMosqueMember(mosqueId);
        }
      }
    }

    match /publicStats/{token} {
      allow get: if true;
      allow list: if false;
      // Transitional: the admin app writes the projection; moves to a Cloud
      // Function (write: if false) in Phase 5.
      //
      // ⚠️ Deliberately NOT `isSignedIn()`: this Firebase project has the
      // Anonymous auth provider enabled (production parent-form.html uses it),
      // and email/password self-signup is reachable via the public Auth REST
      // API — so "any signed-in user" effectively means "anyone". A parent
      // knows their own token from the WhatsApp link and could overwrite
      // their child's published stats. Writes therefore require actual
      // mosque membership.
      //
      // The mosque id is hardcoded because publicStats/{token} carries no
      // mosque context by design (see publicStats.repo.ts). Single tenant
      // today (mirrors MOSQUE_ID in src/config.ts); Phase 5 removes client
      // writes entirely, so this never needs to become multi-tenant.
      allow write: if isMosqueMember('altayseer');
    }
  }
}
